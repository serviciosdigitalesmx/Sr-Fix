{
  "name": "sr-fix",
  "private": true,
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:ts": "tsc -p tsconfig.json",
    "build:css": "tailwindcss -c tailwind.config.cjs -i css/tailwind-input.css -o css/tailwind.generated.css --minify",
    "build": "npm run build:ts && npm run build:css",
    "frontend:ts": "bash ./scripts/frontend-ts.sh",
    "frontend:ts:check": "bash ./scripts/audit-legacy.sh"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
